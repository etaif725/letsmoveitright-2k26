# Server (index.cjs)
PORT=3000

# Email (Resend — used by sendEmail.cjs)
RESEND_API_KEY=re_your_resend_api_key_here
FROM_EMAIL=notifications@send.yourdomain.com
NOTIFICATIONS_EMAILS=
NOTIFICATIONS_CC=someone@example.com
NOTIFICATIONS_BCC=someone@example.com

# HTTPS (optional, set to "true" to enable)
HTTPS=false
SSLCertificateFile=/path/to/cert.pem
SSLCertificateKeyFile=/path/to/key.pem

# Client-side (Vite injects these at build time)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
VITE_GTM_ID=GTM-XXXXXXXX
VITE_GTAG_ID=G-XXXXXXXXXX
VITE_GADS_ID=AW-XXXXXXXXXXX
