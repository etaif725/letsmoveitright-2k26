# Server (index.cjs)
PORT=3000

# Email (Resend — used by sendEmail.cjs)
RESEND_API_KEY=re_XXXXXXXXX
FROM_EMAIL=notifications@send.letsmoveit-right.com
NOTIFICATIONS_EMAILS=lead1@example.com,lead2@example.com
NOTIFICATIONS_CC=
NOTIFICATIONS_BCC=

# HTTPS (optional, set to "true" to enable)
HTTPS=false
SSLCertificateFile=/path/to/cert.pem
SSLCertificateKeyFile=/path/to/key.pem

# Client-side (Vite injects these at build time)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_GTM_ID=GTM-XXXXXXXX
VITE_GTAG_ID=G-XXXXXXXX
